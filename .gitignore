# ============================================
# Root .gitignore — hummingbot_custo repo
# ============================================

# ---- Legacy source dumps (never runtime code) ----
_hb_src_dump/
_tradenote_src/

# ---- OS files ----
.DS_Store
Thumbs.db
desktop.ini

# ---- IDE ----
.vscode/
.idea/
*.swp
*.swo
*~
.cursor/mcp.json

# ---- Python ----
__pycache__/
*.pyc
*.pyo
.venv/
.venv-work/
.venv312/
venv/
.coverage
htmlcov/

# ---- Temp / debug artifacts ----
*.tmp
*.bak
# Ad-hoc screenshots at repo root (Playwright / manual captures)
screenshot*.png
screenshot*.js

# ---- Large data files (never push to git) ----
hbot/data/bot*/desk_events*.jsonl
hbot/data/research/explorations/*/run.log
hbot/reports/verification/paper_exchange_command_journal_latest.json

# ---- Runtime-generated service reports (change every tick) ----
hbot/reports/ops_scheduler/heartbeat.json
hbot/reports/policy/portfolio_allocator_latest.json
hbot/reports/policy/portfolio_allocator_state_latest.json
