# ---- Alertmanager — Telegram (optional) ----
# 1. Message @BotFather on Telegram → /newbot → copy the token.
# 2. Add the bot to a group or DM it, then visit
#    https://api.telegram.org/bot<TOKEN>/getUpdates to find the chat_id.
# 3. Uncomment telegram_configs in monitoring/alertmanager/alertmanager.yml.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---- Dashboard supervision / readiness ----
# Semi-prod recommendation: keep this tight so stale minute/snapshot data is visible fast.
DASHBOARD_DATA_MAX_AGE_S=180
# Required sources for dashboard readiness checks (bot:variant)
DASHBOARD_REQUIRED_BOT_VARIANTS=bot1:a,bot3:a,bot4:a

# ---- LLM Sentiment (PMM+RSI+Hedge strategy) ----
# Grok (xAI) — primary provider
LLM_API_KEY=your_xai_api_key_here
# OpenAI — fallback provider
LLM_FALLBACK_API_KEY=your_openai_api_key_here

# ---- Network / Security ----
# Restrict Grafana/Prometheus to localhost or VPN IP
MONITORING_BIND_IP=127.0.0.1
PGADMIN_DEFAULT_EMAIL=ops@example.com

# ---- Self-healing (watchdog) ----
# Optional: enable service recovery (restart Redis/risk-service when unhealthy)
