# ---- Portfolio risk breaker ----
# Near-real-time portfolio loss/exposure breaker service.
PORTFOLIO_RISK_REALTIME_ENABLED=true
PORTFOLIO_RISK_REALTIME_POLL_MS=1000
PORTFOLIO_RISK_INTERVAL_SEC=300

# ---- Logging ----
LOG_MAX_SIZE=50m
LOG_MAX_FILE=5

# ---- Kill switch ----
# Exchange-level emergency stop service (services/kill_switch).
KILL_SWITCH_DRY_RUN=true
KILL_SWITCH_EXCHANGE=bitget
KILL_SWITCH_STOP_BOT=true
# Optional explicit credentials for kill-switch service.
# If unset, compose falls back to BOT1_BITGET_* for bot1 operations.
KILL_SWITCH_API_KEY=
KILL_SWITCH_SECRET=
KILL_SWITCH_PASSPHRASE=
# Bot container to stop after successful non-dry-run execution.
KILL_SWITCH_BOT_CONTAINER=bot1
# Optional: flatten open position after cancel-all using reduce-only market order.
# Keep false by default; enable in production only after connector/account validation.
KILL_SWITCH_FLATTEN_POSITION=false
