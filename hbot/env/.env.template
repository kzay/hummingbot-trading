# ============================================
# Kzay Capital Trading Infrastructure - Environment Template
# ============================================
# COPY this file to .env and fill in your values:
#   cp .env.template .env
#
# NEVER commit .env to git!
# ============================================

# ---- Global Settings ----
COMPOSE_PROJECT_NAME=kzay-capital
TZ=UTC

# ---- Hummingbot Version (pin to V2!) ----
HUMMINGBOT_IMAGE=hummingbot/hummingbot:version-2.12.0
HUMMINGBOT_DASHBOARD_IMAGE=hummingbot/dashboard:latest

# ---- Bot 1 - Bitget Spot ----
BOT1_NAME=bot1
BOT1_BITGET_API_KEY=your_bitget_api_key_here
BOT1_BITGET_API_SECRET=your_bitget_api_secret_here
BOT1_BITGET_PASSPHRASE=your_bitget_passphrase_here
BOT1_PASSWORD=admin123changeme

# ---- Bot 2 - Bitget Spot (optional) ----
BOT2_NAME=bot2
BOT2_BITGET_API_KEY=your_bitget_api_key_here
BOT2_BITGET_API_SECRET=your_bitget_api_secret_here
BOT2_BITGET_PASSPHRASE=your_bitget_passphrase_here
BOT2_PASSWORD=admin456changeme

# ---- Shared auth for additional desk bots ----
# Keep bot startup fully headless. If BOT3/BOT4/BOT5/BOT6/BOT7 are empty, compose falls back to BOT1_PASSWORD.
# Shared connector files are encrypted once, so bots that use shared connectors should resolve to the same password.
BOT3_PASSWORD=
BOT4_PASSWORD=
BOT5_PASSWORD=
BOT6_PASSWORD=
BOT7_PASSWORD=

# ---- EPP v2.4 toggles ----
EPP_PHASE=0
EPP_PAPER_MODE=true
EPP_CONNECTOR_SPOT=bitget
EPP_CONNECTOR_PERP_MONITOR=bitget_perpetual
EPP_TRADING_PAIR=BTC-USDT

# ---- Runtime mode switches (config-only paper/live) ----
# Keep the same controller config and only flip mode.
BOT1_MODE=paper
BOT3_MODE=paper
BOT4_MODE=live
BOT5_MODE=paper
BOT6_MODE=paper
BOT7_MODE=paper

# ---- Paper exchange rollout modes (disabled|shadow|active|auto) ----
# Use per-bot overrides for canary: start disabled -> shadow -> active.
# `auto` resolves to active only when service heartbeat is fresh; otherwise
# it falls back to PAPER_EXCHANGE_AUTO_FALLBACK (default: shadow).
PAPER_EXCHANGE_MODE_BOT1=disabled
PAPER_EXCHANGE_MODE_BOT3=disabled
PAPER_EXCHANGE_MODE_BOT4=disabled
PAPER_EXCHANGE_MODE_BOT5=disabled
PAPER_EXCHANGE_MODE_BOT6=disabled
PAPER_EXCHANGE_MODE_BOT7=disabled
# Optional strict routing (global or per-bot: PAPER_EXCHANGE_SERVICE_ONLY_BOT<id>).
# true = fail closed to service-active path, never shadow/disabled local routing.
PAPER_EXCHANGE_SERVICE_ONLY=false
PAPER_EXCHANGE_AUTO_FALLBACK=shadow
PAPER_EXCHANGE_AUTO_MAX_HEARTBEAT_AGE_MS=15000
PAPER_EXCHANGE_AUTO_CACHE_MS=5000
PAPER_EXCHANGE_SYNC_TIMEOUT_MS=30000

# ---- External Signal/Risk Stack ----
EXT_SIGNAL_RISK_ENABLED=false
BUS_SOFT_PAUSE_ON_OUTAGE=true
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_BIND_IP=127.0.0.1
REDIS_MAXMEMORY=1536mb
REDIS_MAXMEMORY_POLICY=noeviction
REDIS_CONSUMER_GROUP=hb_group_v1
EVENT_POLL_MS=1000
HB_MARKET_DEPTH_LEVELS=20
RISK_MAX_ABS_SIGNAL=0.25
RISK_MAX_ABS_PREDICTED_RETURN=0.05
HB_STREAM_MAXLEN_MARKET_DATA=50000
