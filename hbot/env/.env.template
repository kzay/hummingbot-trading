# ============================================
# Hummingbot Infrastructure - Environment Template
# ============================================
# COPY this file to .env and fill in your values:
#   cp .env.template .env
#
# NEVER commit .env to git!
# ============================================

# ---- Global Settings ----
COMPOSE_PROJECT_NAME=hbot
TZ=UTC

# ---- Hummingbot Version (pin to V2!) ----
HUMMINGBOT_IMAGE=hummingbot/hummingbot:version-2.12.0
HUMMINGBOT_DASHBOARD_IMAGE=hummingbot/dashboard:latest

# ---- Bot 1 - Bitget Spot ----
BOT1_NAME=bot1
BOT1_BITGET_API_KEY=your_bitget_api_key_here
BOT1_BITGET_API_SECRET=your_bitget_api_secret_here
BOT1_BITGET_PASSPHRASE=your_bitget_passphrase_here
BOT1_PASSWORD=admin123changeme

# ---- Bot 2 - Bitget Spot (optional) ----
BOT2_NAME=bot2
BOT2_BITGET_API_KEY=your_bitget_api_key_here
BOT2_BITGET_API_SECRET=your_bitget_api_secret_here
BOT2_BITGET_PASSPHRASE=your_bitget_passphrase_here
BOT2_PASSWORD=admin456changeme

# ---- Shared auth for additional desk bots ----
# Keep bot startup fully headless. If BOT3/BOT4 are empty, compose falls back to BOT1_PASSWORD.
BOT3_PASSWORD=
BOT4_PASSWORD=

# ---- EPP v2.4 toggles ----
EPP_PHASE=0
EPP_PAPER_MODE=true
EPP_CONNECTOR_SPOT=bitget
EPP_CONNECTOR_PERP_MONITOR=bitget_perpetual
EPP_TRADING_PAIR=BTC-USDT

# ---- Runtime mode switches (config-only paper/live) ----
# Keep the same controller config and only flip mode.
BOT1_MODE=paper
BOT3_MODE=paper
BOT4_MODE=live

# ---- Paper exchange rollout modes (disabled|shadow|active) ----
# Use per-bot overrides for canary: start disabled -> shadow -> active.
PAPER_EXCHANGE_MODE_BOT1=disabled
PAPER_EXCHANGE_MODE_BOT3=disabled
PAPER_EXCHANGE_MODE_BOT4=disabled
PAPER_EXCHANGE_SYNC_TIMEOUT_MS=30000

# ---- External Signal/Risk Stack ----
EXT_SIGNAL_RISK_ENABLED=false
BUS_SOFT_PAUSE_ON_OUTAGE=true
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_BIND_IP=127.0.0.1
REDIS_CONSUMER_GROUP=hb_group_v1
EVENT_POLL_MS=1000
RISK_MAX_ABS_SIGNAL=0.25
RISK_MAX_ABS_PREDICTED_RETURN=0.05

# ---- Paper exchange service wiring (compose profile: paper-exchange) ----
PAPER_EXCHANGE_SERVICE_INSTANCE_NAME=paper_exchange
PAPER_EXCHANGE_CONSUMER_GROUP=hb_group_paper_exchange
PAPER_EXCHANGE_CONSUMER_NAME=paper_exchange_1
PAPER_EXCHANGE_ALLOWED_CONNECTORS=bitget_perpetual
PAPER_EXCHANGE_ALLOWED_COMMAND_PRODUCERS=hb_bridge_active_adapter
PAPER_EXCHANGE_MARKET_STREAM=hb.market_data.v1
PAPER_EXCHANGE_COMMAND_STREAM=hb.paper_exchange.command.v1
PAPER_EXCHANGE_EVENT_STREAM=hb.paper_exchange.event.v1
PAPER_EXCHANGE_HEARTBEAT_STREAM=hb.paper_exchange.heartbeat.v1
PAPER_EXCHANGE_AUDIT_STREAM=hb.audit.v1
PAPER_EXCHANGE_HEARTBEAT_INTERVAL_MS=5000
PAPER_EXCHANGE_MARKET_STALE_AFTER_MS=15000
PAPER_EXCHANGE_READ_COUNT=200
PAPER_EXCHANGE_READ_BLOCK_MS=250
PAPER_EXCHANGE_PENDING_RECLAIM_ENABLED=true
PAPER_EXCHANGE_MARKET_PENDING_RECLAIM_ENABLED=true
PAPER_EXCHANGE_PERSIST_SYNC_STATE_RESULTS=false
EVENT_STORE_DB_MIRROR_ENABLED=false
EVENT_STORE_DB_MIRROR_REQUIRED=false
EVENT_STORE_DB_APPEND_RETRIES=3

# ---- ML Signal Runtime (Phase 1 MVP) ----
ML_ENABLED=false
ML_RUNTIME=sklearn_joblib
ML_MODEL_SOURCE=local
ML_MODEL_URI=/workspace/hbot/models/current/model.joblib
ML_MODEL_REFRESH_SEC=300
ML_CONFIDENCE_MIN=0.60
ML_MAX_SIGNAL_AGE_MS=3000
ML_INFERENCE_TIMEOUT_MS=200
ML_HORIZON_S=60
ML_FEATURE_SET=v1
ML_CUSTOM_CLASS_PATH=
ML_S3_HTTP_TIMEOUT_SEC=10

# ---- Grafana ----
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=GrafanaSecure2024!
GF_SERVER_ROOT_URL=http://localhost:3000
GF_SERVER_SERVE_FROM_SUB_PATH=false

# ---- Prometheus ----
PROMETHEUS_RETENTION=30d
PROMETHEUS_RETENTION_SIZE=5GB

# ---- Ops DB / Timescale (canonical data plane) ----
OPS_DB_IMAGE=timescale/timescaledb:latest-pg16
OPS_DB_SHARED_PRELOAD_LIBRARIES=timescaledb
OPS_DB_BIND_IP=127.0.0.1
OPS_DB_PORT=5432
OPS_DB_NAME=hbot_ops
OPS_DB_USER=hbot
OPS_DB_PASSWORD=hbot_dev_password
OPS_DB_WRITER_INTERVAL_SEC=300
OPS_DB_TIMESCALE_ENABLED=true
OPS_DB_TIMESCALE_REQUIRED=false
OPS_DB_TIMESCALE_ENABLE_COMPRESSION=false
OPS_DB_TS_RETENTION_EVENTS_DAYS=30
OPS_DB_TS_RETENTION_MINUTE_DAYS=90
OPS_DB_TS_RETENTION_FILLS_DAYS=365
OPS_DB_TS_COMPRESS_AFTER_EVENTS_DAYS=2
OPS_DB_TS_COMPRESS_AFTER_MINUTE_DAYS=3
OPS_DB_TS_COMPRESS_AFTER_FILLS_DAYS=7

# ---- Alertmanager — Telegram (optional) ----
# 1. Message @BotFather on Telegram → /newbot → copy the token.
# 2. Add the bot to a group or DM it, then visit
#    https://api.telegram.org/bot<TOKEN>/getUpdates to find the chat_id.
# 3. Uncomment telegram_configs in monitoring/alertmanager/alertmanager.yml.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---- TradeNote (self-hosted journal; compose profile: tradenote) ----
# Start with:
# docker compose --env-file ../env/.env -f compose/docker-compose.yml --profile tradenote up -d tradenote tradenote-mongo tradenote-sync
TRADENOTE_BIND_IP=127.0.0.1
TRADENOTE_PORT=8080
TRADENOTE_URL=http://tradenote:8080
TRADENOTE_APP_ID=replace_me_app_id
TRADENOTE_MASTER_KEY=replace_me_master_key
TRADENOTE_MONGO_USER=tradenote
TRADENOTE_MONGO_PASSWORD=tradenote_change_me
TRADENOTE_MONGO_DB=tradenote
TRADENOTE_API_KEY=
TRADENOTE_SELECTED_BROKER=template
TRADENOTE_UPLOAD_MFE=false
TRADENOTE_SYNC_INTERVAL_SEC=1800
TRADENOTE_SYNC_INCLUDE_TODAY=false
TRADENOTE_SYNC_LOOKBACK_DAYS=14
# Optional filter (default empty = all discovered fills.csv):
# TRADENOTE_SYNC_BOT_VARIANTS=bot1:a,bot3:a
TRADENOTE_SYNC_BOT_VARIANTS=
TRADENOTE_ACCOUNT_PREFIX=hbot
TRADENOTE_SECURITY_TYPE=0
TRADENOTE_SETTLEMENT_DAYS=0
TRADENOTE_SYNC_MAX_DAYS_PER_RUN=2
TRADENOTE_SYNC_MAX_ROWS_PER_POST=100
TRADENOTE_SYNC_REQUEST_TIMEOUT_SEC=20
TRADENOTE_SYNC_REQUEST_MAX_ATTEMPTS=3
TRADENOTE_SYNC_STATE_PATH=/workspace/hbot/reports/tradenote/sync_state.json
TRADENOTE_SYNC_REPORT_PATH=/workspace/hbot/reports/tradenote/sync_latest.json
TRADENOTE_SYNC_HEALTH_MAX_SEC=5400

# ---- LLM Sentiment (PMM+RSI+Hedge strategy) ----
# Grok (xAI) — primary provider
LLM_API_KEY=your_xai_api_key_here
# OpenAI — fallback provider
LLM_FALLBACK_API_KEY=your_openai_api_key_here

# ---- Network / Security ----
# Restrict Grafana/Prometheus to localhost or VPN IP
MONITORING_BIND_IP=127.0.0.1

# ---- Self-healing (watchdog) ----
# Optional: enable service recovery (restart Redis/risk-service when unhealthy)
WATCHDOG_SERVICE_RECOVERY_ENABLED=false

# ---- Portfolio risk breaker ----
# Near-real-time portfolio loss/exposure breaker service.
PORTFOLIO_RISK_REALTIME_ENABLED=true
PORTFOLIO_RISK_REALTIME_POLL_MS=1000
PORTFOLIO_RISK_INTERVAL_SEC=300

# ---- Logging ----
LOG_MAX_SIZE=50m
LOG_MAX_FILE=5

# ---- Kill switch ----
# Exchange-level emergency stop service (services/kill_switch).
KILL_SWITCH_DRY_RUN=true
KILL_SWITCH_EXCHANGE=bitget
KILL_SWITCH_STOP_BOT=true
# Optional: flatten open position after cancel-all using reduce-only market order.
# Keep false by default; enable in production only after connector/account validation.
KILL_SWITCH_FLATTEN_POSITION=false
