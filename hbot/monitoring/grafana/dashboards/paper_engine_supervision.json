{
  "uid": "kzay-capital-paper-engine-supervision",
  "title": "Kzay Capital Paper Engine Supervision",
  "tags": ["kzay-capital", "paper-engine", "supervision"],
  "timezone": "utc",
  "schemaVersion": 39,
  "version": 2,
  "style": "dark",
  "editable": true,
  "graphTooltip": 1,
  "liveNow": true,
  "refresh": "10s",
  "time": { "from": "now-6h", "to": "now" },
  "links": [
    {
      "title": "Kzay Capital Trading Desk",
      "type": "link",
      "url": "/d/kzay-capital-trading-overview",
      "keepTime": true,
      "includeVars": true,
      "targetBlank": false,
      "icon": "external link"
    },
    {
      "title": "Kzay Capital Ops & Infrastructure",
      "type": "link",
      "url": "/d/kzay-capital-cp-health",
      "keepTime": true,
      "includeVars": false,
      "targetBlank": false,
      "icon": "external link"
    }
  ],
  "templating": {
    "list": [
      {
        "name": "cluster",
        "label": "Cluster",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(hbot_bot_state, cluster)",
        "includeAll": true,
        "multi": true,
        "allValue": ".+",
        "refresh": 2,
        "sort": 1,
        "current": { "text": "All", "value": ["$__all"] }
      },
      {
        "name": "environment",
        "label": "Environment",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(hbot_bot_state{cluster=~\"$cluster\"}, environment)",
        "includeAll": true,
        "multi": true,
        "allValue": ".+",
        "refresh": 2,
        "sort": 1,
        "current": { "text": "All", "value": ["$__all"] }
      },
      {
        "name": "bot",
        "label": "Bot",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(hbot_bot_state{cluster=~\"$cluster\",environment=~\"$environment\"}, bot)",
        "includeAll": true,
        "multi": true,
        "allValue": ".+",
        "refresh": 2,
        "sort": 1,
        "current": { "text": "All", "value": ["$__all"] }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "— Real-time Status —",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 2,
      "title": "Engine Service Status",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "max by (instance) (hbot_paper_exchange_service_up{cluster=~\"$cluster\",environment=~\"$environment\"})",
          "refId": "A",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "1": { "text": "UP", "color": "green" },
                "0": { "text": "DOWN", "color": "red" }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 1, "color": "green" }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "id": 3,
      "title": "Engine Heartbeat Age",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "max by (instance) (hbot_paper_exchange_heartbeat_age_seconds{cluster=~\"$cluster\",environment=~\"$environment\"})",
          "refId": "A",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 10, "color": "orange" },
              { "value": 30, "color": "red" }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 4,
      "title": "Margin Call & Liquidation Events",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "(sum(hbot_bot_paper_margin_call_events_total{cluster=~\"$cluster\",environment=~\"$environment\",bot=~\"$bot\"}) or vector(0)) + (sum(hbot_bot_paper_liquidation_events_total{cluster=~\"$cluster\",environment=~\"$environment\",bot=~\"$bot\"}) or vector(0))",
          "refId": "A",
          "legendFormat": "Total Events"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 1, "color": "red" }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "id": 5,
      "title": "Command Rejection Rate",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "100 * (sum(rate(hbot_paper_exchange_command_total{cluster=~\"$cluster\",environment=~\"$environment\",status=\"rejected\"}[5m])) or vector(0)) / clamp_min(sum(rate(hbot_paper_exchange_command_total{cluster=~\"$cluster\",environment=~\"$environment\"}[5m])), 0.001)",
          "refId": "A",
          "legendFormat": "Rejection %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 1, "color": "orange" },
              { "value": 5, "color": "red" }
            ]
          },
          "decimals": 2
        }
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 6,
      "title": "— Performance & Latency —",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 6 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 7,
      "title": "Submit to First Fill Latency (P95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "hbot_paper_exchange_submit_to_first_fill_latency_p95_ms{cluster=~\"$cluster\",environment=~\"$environment\"}",
          "refId": "A",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "opacity"
          }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "none" }
      }
    },
    {
      "id": 10,
      "title": "Command Processing Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (status) (rate(hbot_paper_exchange_command_total{cluster=~\"$cluster\",environment=~\"$environment\"}[1m]))",
          "refId": "A",
          "legendFormat": "{{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "opacity"
          }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "none" }
      }
    },
    {
      "id": 8,
      "title": "Oldest Snapshot Age",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "hbot_paper_exchange_oldest_snapshot_age_ms{cluster=~\"$cluster\",environment=~\"$environment\"}",
          "refId": "A",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "opacity"
          }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "none" }
      }
    },
    {
      "id": 9,
      "title": "Load Backlog Growth (Per 10m)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "hbot_paper_exchange_load_backlog_growth_pct_per_10m{cluster=~\"$cluster\",environment=~\"$environment\"}",
          "refId": "A",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "opacity"
          }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "none" }
      }
    },
    {
      "id": 11,
      "title": "Current Snapshot Age by Trading Pair",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 23 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sort_desc(max by (pair) (hbot_paper_exchange_pair_snapshot_age_seconds{cluster=~\"$cluster\",environment=~\"$environment\"}))",
          "refId": "A",
          "legendFormat": "{{pair}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 80
          }
        }
      },
      "options": {
        "orientation": "horizontal",
        "showValue": "auto",
        "text": {
          "valueSize": 12
        },
        "legend": {
          "displayMode": "hidden"
        }
      }
    }
  ]
}