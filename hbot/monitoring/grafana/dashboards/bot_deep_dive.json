{
  "uid": "hbot-bot-deep-dive",
  "title": "Bot Deep Dive",
  "tags": ["hummingbot", "trading", "deep-dive"],
  "timezone": "utc",
  "schemaVersion": 39,
  "version": 10,
  "style": "dark",
  "editable": true,
  "graphTooltip": 1,
  "liveNow": false,
  "refresh": "30s",
  "time": { "from": "now-12h", "to": "now" },
  "links": [
    {
      "title": "Back to Trading Desk",
      "type": "link",
      "url": "/d/hbot-trading-overview",
      "keepTime": true,
      "includeVars": true,
      "targetBlank": false,
      "icon": "arrow-left"
    },
    {
      "title": "Ops & Infrastructure",
      "type": "link",
      "url": "/d/hbot-cp-health",
      "keepTime": true,
      "includeVars": false,
      "targetBlank": false,
      "icon": "external link"
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      },
      {
        "datasource": { "type": "loki", "uid": "loki" },
        "enable": true,
        "expr": "{job=\"bot_logs\"} |= \"kill_switch\"",
        "hide": false,
        "iconColor": "red",
        "name": "Kill Switch Events",
        "step": "60s"
      },
      {
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "enable": true,
        "expr": "changes(container_start_time_seconds{name=~\"hbot-$bot\"}[15m]) > 0",
        "hide": false,
        "iconColor": "orange",
        "name": "Container Restart",
        "step": "60s",
        "titleFormat": "Restart"
      }
    ]
  },
  "templating": {
    "list": [
      {
        "name": "cluster",
        "label": "Cluster",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(hbot_bot_state, cluster)",
        "includeAll": true,
        "multi": true,
        "allValue": ".+",
        "refresh": 2,
        "sort": 1,
        "current": { "text": "All", "value": ["$__all"] }
      },
      {
        "name": "environment",
        "label": "Environment",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(hbot_bot_state{cluster=~\"$cluster\"}, environment)",
        "includeAll": true,
        "multi": true,
        "allValue": ".+",
        "refresh": 2,
        "sort": 1,
        "current": { "text": "All", "value": ["$__all"] }
      },
      {
        "name": "bot",
        "label": "Bot",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(hbot_bot_state{cluster=~\"$cluster\",environment=~\"$environment\"}, bot)",
        "includeAll": false,
        "multi": false,
        "refresh": 2,
        "sort": 1,
        "current": { "text": "bot1", "value": "bot1" }
      },
      {
        "name": "exchange",
        "label": "Exchange",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(hbot_bot_state{cluster=~\"$cluster\",environment=~\"$environment\",bot=~\"$bot\"}, exchange)",
        "includeAll": true,
        "multi": false,
        "allValue": ".+",
        "refresh": 2,
        "sort": 1,
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "symbol",
        "label": "Symbol",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(hbot_bot_state{cluster=~\"$cluster\",environment=~\"$environment\",bot=~\"$bot\",exchange=~\"$exchange\"}, pair)",
        "includeAll": true,
        "multi": false,
        "allValue": ".+",
        "refresh": 2,
        "sort": 1,
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "strategy",
        "label": "Strategy",
        "description": "Maps to Prometheus label `variant`.",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(hbot_bot_state{cluster=~\"$cluster\",environment=~\"$environment\",bot=~\"$bot\",exchange=~\"$exchange\",pair=~\"$symbol\"}, variant)",
        "includeAll": true,
        "multi": false,
        "allValue": ".+",
        "refresh": 2,
        "sort": 1,
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "venue",
        "label": "Venue",
        "description": "Maps to Prometheus label `mode` (paper/live).",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(hbot_bot_state{cluster=~\"$cluster\",environment=~\"$environment\",bot=~\"$bot\",exchange=~\"$exchange\",pair=~\"$symbol\",variant=~\"$strategy\"}, mode)",
        "includeAll": true,
        "multi": false,
        "allValue": ".+",
        "refresh": 2,
        "sort": 1,
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "regime",
        "label": "Regime",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(hbot_bot_state{cluster=~\"$cluster\",environment=~\"$environment\",bot=~\"$bot\",exchange=~\"$exchange\",pair=~\"$symbol\",variant=~\"$strategy\",mode=~\"$venue\"}, regime)",
        "includeAll": true,
        "multi": false,
        "allValue": ".+",
        "refresh": 2,
        "sort": 1,
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "timeframe",
        "label": "Timeframe",
        "type": "custom",
        "query": "5m,15m,1h",
        "current": { "text": "15m", "value": "15m" }
      }
    ]
  },
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "Desk Triage",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 1,
      "type": "stat",
      "title": "Bot State",
      "description": "RUNNING = placing orders; SOFT PAUSE = edge/risk gate blocking; HARD STOP = emergency halt.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "targets": [
        {
          "expr": "sum without(state) ((hbot_bot_state{cluster=~\"$cluster\",environment=~\"$environment\",bot=~\"$bot\",exchange=~\"$exchange\",pair=~\"$symbol\",variant=~\"$strategy\",mode=~\"$venue\",regime=~\"$regime\",state=\"running\"} * 1) or (hbot_bot_state{cluster=~\"$cluster\",environment=~\"$environment\",bot=~\"$bot\",exchange=~\"$exchange\",pair=~\"$symbol\",variant=~\"$strategy\",mode=~\"$venue\",regime=~\"$regime\",state=\"soft_pause\"} * 2) or (hbot_bot_state{cluster=~\"$cluster\",environment=~\"$environment\",bot=~\"$bot\",exchange=~\"$exchange\",pair=~\"$symbol\",variant=~\"$strategy\",mode=~\"$venue\",regime=~\"$regime\",state=\"hard_stop\"} * 3))",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": { "mode": "thresholds" },
          "mappings": [
            {
              "type": "value",
              "options": {
                "1": { "text": "RUNNING", "color": "green", "index": 0 },
                "2": { "text": "SOFT PAUSE", "color": "orange", "index": 1 },
                "3": { "text": "HARD STOP", "color": "red", "index": 2 }
              }
            }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 2 }, { "color": "red", "value": 3 }] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "values": false, "calcs": ["lastNotNull"] }, "textMode": "value", "colorMode": "background", "graphMode": "none", "justifyMode": "center" }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Snapshot Age",
      "description": "Age of latest minute.csv snapshot. Green < 60s. Red > 300s (bot stuck / exporter reading stale file).",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "targets": [
        { "expr": "hbot_bot_snapshot_age_seconds{cluster=~\"$cluster\",environment=~\"$environment\",bot=~\"$bot\",exchange=~\"$exchange\",pair=~\"$symbol\",variant=~\"$strategy\",mode=~\"$venue\",regime=~\"$regime\"}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 60 }, { "color": "red", "value": 300 }] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "values": false, "calcs": ["lastNotNull"] }, "textMode": "value_and_name", "colorMode": "value", "graphMode": "area", "justifyMode": "center" }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Net Edge",
      "description": "Net edge after fees & adverse selection (proxy). Positive is required for profitable MM at current spread.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "targets": [
        { "expr": "hbot_bot_net_edge_pct{cluster=~\"$cluster\",environment=~\"$environment\",bot=~\"$bot\",exchange=~\"$exchange\",pair=~\"$symbol\",variant=~\"$strategy\",mode=~\"$venue\",regime=~\"$regime\"} * 10000", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 1,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 0 }, { "color": "green", "value": 1 }] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "values": false, "calcs": ["lastNotNull"] }, "textMode": "value_and_name", "colorMode": "value", "graphMode": "none", "justifyMode": "center" }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Equity / PnL Today",
      "description": "Equity quote + today's mark-to-market PnL (derived).",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "targets": [
        { "expr": "hbot_bot_equity_quote{cluster=~\"$cluster\",environment=~\"$environment\",bot=~\"$bot\",exchange=~\"$exchange\",pair=~\"$symbol\",variant=~\"$strategy\",mode=~\"$venue\",regime=~\"$regime\"}", "refId": "A", "instant": true },
        { "expr": "hbot_bot_daily_pnl_quote{cluster=~\"$cluster\",environment=~\"$environment\",bot=~\"$bot\",exchange=~\"$exchange\",pair=~\"$symbol\",variant=~\"$strategy\",mode=~\"$venue\",regime=~\"$regime\"}", "refId": "B", "instant": true }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 2 }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "horizontal", "textMode": "value_and_name", "colorMode": "value", "graphMode": "none", "justifyMode": "center" }
    },
    {
      "id": 110,
      "type": "row",
      "title": "Performance & PnL (Expand)",
      "collapsed": true,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 20 }
    },
    {
      "id": 111,
      "type": "timeseries",
      "title": "Equity",
      "description": "Equity quote over time (exported from minute.csv).",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 21 },
      "targets": [
        {
          "expr": "hbot_bot_equity_quote{cluster=~\"$cluster\",environment=~\"$environment\",bot=~\"$bot\",exchange=~\"$exchange\",pair=~\"$symbol\",variant=~\"$strategy\",mode=~\"$venue\",regime=~\"$regime\"}",
          "legendFormat": "equity",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 2, "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" }, "color": { "mode": "fixed", "fixedColor": "blue" } }, "overrides": [] },
      "options": { "tooltip": { "mode": "single" }, "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["last", "max"] } }
    },
    {
      "id": 112,
      "type": "timeseries",
      "title": "PnL Today (MTM) + Realized",
      "description": "MTM PnL derived from equity open→now (exporter) vs realized PnL from fills.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 21 },
      "targets": [
        {
          "expr": "hbot_bot_daily_pnl_quote{cluster=~\"$cluster\",environment=~\"$environment\",bot=~\"$bot\",exchange=~\"$exchange\",pair=~\"$symbol\",variant=~\"$strategy\",mode=~\"$venue\",regime=~\"$regime\"}",
          "legendFormat": "mtm",
          "refId": "A"
        },
        {
          "expr": "hbot_bot_net_realized_pnl_today_quote{cluster=~\"$cluster\",environment=~\"$environment\",bot=~\"$bot\",exchange=~\"$exchange\",pair=~\"$symbol\",variant=~\"$strategy\",mode=~\"$venue\",regime=~\"$regime\"}",
          "legendFormat": "realized",
          "refId": "B"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 2, "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" } }, "overrides": [] },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["last"] } }
    },
    {
      "id": 120,
      "type": "row",
      "title": "Risk Detail (Expand)",
      "collapsed": true,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 28 }
    },
    {
      "id": 121,
      "type": "stat",
      "title": "Position (base)",
      "description": "Signed base position. >0 long, <0 short.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 29 },
      "targets": [
        { "expr": "hbot_bot_position_base{cluster=~\"$cluster\",environment=~\"$environment\",bot=~\"$bot\",exchange=~\"$exchange\",pair=~\"$symbol\",variant=~\"$strategy\",mode=~\"$venue\",regime=~\"$regime\"}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "none", "decimals": 6 }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value", "colorMode": "value", "graphMode": "none", "justifyMode": "center" }
    },
    {
      "id": 122,
      "type": "stat",
      "title": "Avg Entry",
      "description": "Average entry price of current position.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 29 },
      "targets": [
        { "expr": "hbot_bot_avg_entry_price{cluster=~\"$cluster\",environment=~\"$environment\",bot=~\"$bot\",exchange=~\"$exchange\",pair=~\"$symbol\",variant=~\"$strategy\",mode=~\"$venue\",regime=~\"$regime\"}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 2 }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value", "colorMode": "value", "graphMode": "none", "justifyMode": "center" }
    },
    {
      "id": 123,
      "type": "stat",
      "title": "Margin Ratio",
      "description": "Futures/perps only. Lower = closer to liquidation.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 29 },
      "targets": [
        { "expr": "hbot_bot_margin_ratio{cluster=~\"$cluster\",environment=~\"$environment\",bot=~\"$bot\",exchange=~\"$exchange\",pair=~\"$symbol\",variant=~\"$strategy\",mode=~\"$venue\",regime=~\"$regime\"}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "none", "decimals": 3, "min": 0, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 0.15 }, { "color": "green", "value": 0.3 }] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value", "colorMode": "value", "graphMode": "none", "justifyMode": "center" }
    },
    {
      "id": 124,
      "type": "stat",
      "title": "Risk Reasons",
      "description": "Controller-reported active risk flags (label `reasons`).",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 29 },
      "targets": [
        { "expr": "hbot_bot_risk_reasons_info{cluster=~\"$cluster\",environment=~\"$environment\",bot=~\"$bot\",exchange=~\"$exchange\",pair=~\"$symbol\",variant=~\"$strategy\",mode=~\"$venue\",regime=~\"$regime\"}", "legendFormat": "{{reasons}}", "refId": "A", "instant": true }
      ],
      "fieldConfig": { "defaults": { "unit": "none", "color": { "mode": "fixed", "fixedColor": "text" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "name", "colorMode": "none", "graphMode": "none", "justifyMode": "center" }
    },
    {
      "id": 130,
      "type": "row",
      "title": "Execution & Controls (Expand)",
      "collapsed": true,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 33 }
    },
    {
      "id": 131,
      "type": "stat",
      "title": "Fills (Δ $timeframe)",
      "description": "New fills over selected window (delta of fills row count; clamped at 0 to ignore restarts).",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 34 },
      "targets": [
        { "expr": "sum(clamp_min(delta(hbot_bot_fills_total{cluster=~\"$cluster\",environment=~\"$environment\",bot=~\"$bot\",exchange=~\"$exchange\",pair=~\"$symbol\",variant=~\"$strategy\",mode=~\"$venue\",regime=~\"$regime\"}[$timeframe]), 0))", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0 }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value", "colorMode": "value", "graphMode": "none", "justifyMode": "center" }
    },
    {
      "id": 132,
      "type": "stat",
      "title": "Cancel Rate (per min)",
      "description": "Cancel-per-minute snapshot. Spikes often indicate spread too tight or market moving away.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 34 },
      "targets": [
        { "expr": "hbot_bot_cancel_per_min{cluster=~\"$cluster\",environment=~\"$environment\",bot=~\"$bot\",exchange=~\"$exchange\",pair=~\"$symbol\",variant=~\"$strategy\",mode=~\"$venue\",regime=~\"$regime\"}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 2 }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value", "colorMode": "value", "graphMode": "none", "justifyMode": "center" }
    },
    {
      "id": 133,
      "type": "stat",
      "title": "Tick Duration",
      "description": "End-to-end tick wall time.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 34 },
      "targets": [
        { "expr": "1000 * hbot_bot_tick_duration_seconds{cluster=~\"$cluster\",environment=~\"$environment\",bot=~\"$bot\",exchange=~\"$exchange\",pair=~\"$symbol\",variant=~\"$strategy\",mode=~\"$venue\",regime=~\"$regime\"}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "ms", "decimals": 0 }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value_and_name", "colorMode": "value", "graphMode": "none", "justifyMode": "center" }
    },
    {
      "id": 134,
      "type": "stat",
      "title": "WS Reconnects (Δ $timeframe)",
      "description": "Connectivity stability proxy: delta of reconnect count gauge (clamped at 0).",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 34 },
      "targets": [
        { "expr": "clamp_min(delta(hbot_bot_ws_reconnect_total{cluster=~\"$cluster\",environment=~\"$environment\",bot=~\"$bot\",exchange=~\"$exchange\",pair=~\"$symbol\",variant=~\"$strategy\",mode=~\"$venue\",regime=~\"$regime\"}[$timeframe]), 0)", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0 }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value_and_name", "colorMode": "value", "graphMode": "none", "justifyMode": "center" }
    },
    {
      "id": 135,
      "type": "timeseries",
      "title": "Tick Breakdown (Indicator vs Connector I/O)",
      "description": "If total tick time increases, this isolates whether the slowdown is in indicator compute or connector I/O.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 38 },
      "targets": [
        { "expr": "1000 * hbot_bot_tick_indicator_seconds{cluster=~\"$cluster\",environment=~\"$environment\",bot=~\"$bot\",exchange=~\"$exchange\",pair=~\"$symbol\",variant=~\"$strategy\",mode=~\"$venue\",regime=~\"$regime\"}", "legendFormat": "indicator", "refId": "A" },
        { "expr": "1000 * hbot_bot_tick_connector_io_seconds{cluster=~\"$cluster\",environment=~\"$environment\",bot=~\"$bot\",exchange=~\"$exchange\",pair=~\"$symbol\",variant=~\"$strategy\",mode=~\"$venue\",regime=~\"$regime\"}", "legendFormat": "connector_io", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "ms", "decimals": 0, "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" } }, "overrides": [] },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["last", "max"] } }
    },
    {
      "id": 136,
      "type": "timeseries",
      "title": "Governor & Competitiveness Controls",
      "description": "Shows applied size multiplier, spread competitiveness cap status, and effective daily % equity target.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 45 },
