                  {
                    "type": "value",
                    "options": {
                      "daily_loss": { "text": "Daily Loss (Hard Limit)" },
                      "drawdown": { "text": "Drawdown (Hard Limit)" },
                      "turnover": { "text": "Turnover (Hard Limit)" },
                      "position_drift": { "text": "Position Drift (Soft Pause)" },
