{
  "version": 1,
  "default_mode": "apply",
  "rules": [
    {
      "name": "event_store",
      "glob": "reports/event_store/*",
      "keep_days": 14
    },
    {
      "name": "reconciliation",
      "glob": "reports/reconciliation/*",
      "keep_days": 30
    },
    {
      "name": "parity",
