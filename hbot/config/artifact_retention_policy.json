    {
      "name": "bot_hummingbot_logs",
      "glob": "data/bot*/logs/*.log*",
      "keep_days": 7
    },
    {
      "name": "bot_error_logs",
      "glob": "data/bot*/logs/errors.log*",
      "keep_days": 14
    },
    {
      "name": "bot_archive",
      "glob": "data/bot*/archive/*",
      "keep_days": 30
    },
    {
      "name": "exchange_snapshots",
      "glob": "reports/exchange_snapshots/*",
      "keep_days": 30
    },
    {
      "name": "market_data_service",
      "glob": "reports/market_data_service/*",
      "keep_days": 14
    },
    {
      "name": "coordination",
      "glob": "reports/coordination/*",
      "keep_days": 30
    },
    {
      "name": "desk_snapshot",
      "glob": "reports/desk_snapshot/**/*",
      "keep_days": 14
    },
    {
      "name": "strategy",
      "glob": "reports/strategy/*",
      "keep_days": 30
    },
    {
      "name": "kill_switch",
      "glob": "reports/kill_switch/*",
      "keep_days": 90
    }
