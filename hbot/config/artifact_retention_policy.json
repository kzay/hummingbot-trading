      "keep_days": 30
    },
    {
      "name": "ops_db_writer",
      "glob": "reports/ops_db_writer/*",
      "keep_days": 30
    },
    {
      "name": "bot_minute_csv",
      "glob": "data/bot*/logs/**/minute*.csv",
      "keep_days": 30
    },
    {
      "name": "bot_fills_csv",
      "glob": "data/bot*/logs/**/fills*.csv",
      "keep_days": 90
